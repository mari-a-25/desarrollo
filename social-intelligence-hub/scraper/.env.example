# ============================================================
# Social Intelligence Hub - Variables de entorno Scraper
# Copiar como .env y completar con valores reales
# ============================================================

# Supabase (usar service_role key para el scraper - tiene permisos de escritura)
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Azure AI Language (obtener en: https://portal.azure.com)
# Crear recurso: Azure AI Language → Capa gratuita F0 (5,000 transacciones/mes)
AZURE_LANGUAGE_ENDPOINT=https://TU_RECURSO.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=TU_CLAVE_DE_32_CARACTERES

# Opcional: Reddit API (para mayor volumen de resultados)
# Crear app en: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SocialIntelligenceHub/1.0

# Opcional: Google Places API (para Google Reviews sin scraping)
# Cuota gratuita: $200/mes de crédito → ~2,000 requests
GOOGLE_PLACES_API_KEY=
